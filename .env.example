# =============================================
# XLSForm Converter — Environment Variables
# =============================================

# --- Sumopod AI API ---
SUMOPOD_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=claude-sonnet-4-6

# --- Performa ---
# API_TIMEOUT : timeout per chunk dalam detik (default 600 = 10 menit)
API_TIMEOUT=600
# CHUNK_SIZE  : karakter per chunk (default 4000)
#   Lebih kecil = tiap chunk lebih cepat, lebih banyak request paralel
#   Lebih besar = lebih sedikit request, tapi tiap chunk lebih lama
CHUNK_SIZE=4000
# MAX_TOKENS  : batas output token per chunk (default 6000)
MAX_TOKENS=6000
# MAX_WORKERS : jumlah chunk diproses paralel sekaligus (default 3)
#   Naikkan ke 4-5 jika koneksi bagus, turunkan ke 1-2 jika sering timeout
MAX_WORKERS=3

# --- Flask ---
FLASK_ENV=development
PORT=5000
SECRET_KEY=ganti-dengan-string-acak-yang-panjang

# --- LibreOffice (untuk konversi file .doc legacy) ---
# Kosongkan jika LibreOffice ada di PATH atau di C:/D: Program Files (dicek otomatis)
# Isi jika install di lokasi custom, contoh:
# SOFFICE_PATH=D:\Apps\LibreOffice\program\soffice.exe
SOFFICE_PATH=
